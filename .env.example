# Copy this file to .env.local and fill in the values you need.
# Everything is optional — with nothing set, the app runs in demo mode
# (localStorage persistence, no auth, simulated "boost").

# --- Supabase (database + auth) ---
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the Stripe webhook to mark listings boosted.
# NEVER prefix this with NEXT_PUBLIC_ — it must not reach the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (paid "boost/feature a listing") ---
# Stripe → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe → Developers → Webhooks → signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Price of a boost in cents (default 500 = $5)
BOOST_PRICE_CENTS=500

# Your public site URL (used for Stripe redirect URLs), e.g. https://roommatch.co
NEXT_PUBLIC_SITE_URL=
